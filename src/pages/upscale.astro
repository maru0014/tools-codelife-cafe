---
import { getEntry } from 'astro:content';
import ToolLayout from '../components/tool/ToolLayout.astro';
import UpscaleTool from '../components/upscale/UpscalePage.tsx';

const toolEntry = await getEntry('tools', 'upscale');
if (!toolEntry) {
  throw new Error('Tool entry not found: upscale');
}
---

<ToolLayout tool={toolEntry}>
  <UpscaleTool client:load />
</ToolLayout>
