---
import { getEntry } from 'astro:content';
import ToolLayout from '../components/tool/ToolLayout.astro';
import { WordCloudPage } from '../components/wordcloud/WordCloudPage';

const toolEntry = await getEntry('tools', 'wordcloud');
if (!toolEntry) {
  throw new Error('Tool entry not found: wordcloud');
}
---

<ToolLayout tool={toolEntry}>
  <WordCloudPage client:load />
</ToolLayout>
