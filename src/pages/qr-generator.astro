---
import { getEntry } from 'astro:content';
import ToolLayout from '../components/tool/ToolLayout.astro';
import QrGeneratorTool from '../components/tools/QrGenerator.tsx';

const toolEntry = await getEntry('tools', 'qr-generator');
if (!toolEntry) {
  throw new Error('Tool entry not found: qr-generator');
}
---

<ToolLayout tool={toolEntry}>
  <QrGeneratorTool client:load />
</ToolLayout>
