---
import { getEntry } from 'astro:content';
import ToolLayout from '../components/tool/ToolLayout.astro';
import { JsonCsvPage } from '../components/tools/json-csv/JsonCsvPage';

const toolEntry = await getEntry('tools', 'json-csv');
if (!toolEntry) {
  throw new Error('Tool entry not found: json-csv');
}
---

<ToolLayout tool={toolEntry}>
  <JsonCsvPage client:load />
</ToolLayout>
