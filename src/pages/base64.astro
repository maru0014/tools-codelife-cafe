---
import { getEntry } from 'astro:content';
import ToolLayout from '../components/tool/ToolLayout.astro';
import Base64Converter from '../components/tools/Base64Converter.tsx';

const toolEntry = await getEntry('tools', 'base64');
if (!toolEntry) {
  throw new Error('Tool entry not found: base64');
}
---

<ToolLayout tool={toolEntry}>
  <Base64Converter client:load />
</ToolLayout>
