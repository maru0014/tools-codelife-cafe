---
import { getEntry } from 'astro:content';
import ToolLayout from '../components/tool/ToolLayout.astro';
import RegexTesterTool from '../components/tools/RegexTester.tsx';

const toolEntry = await getEntry('tools', 'regex-tester');
if (!toolEntry) {
  throw new Error('Tool entry not found: regex-tester');
}
---

<ToolLayout tool={toolEntry}>
  <RegexTesterTool client:load />
</ToolLayout>
