---
import BaseLayout from '../layouts/BaseLayout.astro';
import ToolCard from '../components/common/ToolCard.astro';
import JsonLd from '../components/common/JsonLd.astro';
import { ShieldCheck } from 'lucide-react';
import { getCategoryId, purposeCategories, toolCatalog, toolCategories } from '../lib/tools/catalog';
import { getPopularTools } from '../lib/tools/popularity';

const popularTools = getPopularTools(toolCatalog);


const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": "https://tools.codelife.cafe/#website",
      "name": "CODE:LIFE Tools",
      "url": "https://tools.codelife.cafe",
      "description": "仕事で安心して使える、高速・軽量なWebツール集",
      "inLanguage": "ja",
      "publisher": {
        "@id": "https://tools.codelife.cafe/#org"
      }
    },
    {
      "@type": "Person",
      "@id": "https://tools.codelife.cafe/#org",
      "name": "marumo",
      "url": "https://tools.codelife.cafe",
      "sameAs": [
        "https://github.com/maru0014",
        "https://github.com/maru0014/tools-codelife-cafe"
      ]
    }
  ]
};
---

<BaseLayout
  title="仕事で安心して使えるWebツール集"
  description="すべてのツールがブラウザ内で完結。サーバーへのデータ送信は一切行わない、高速・軽量なWebツール集です。"
  path="/"
>
  <Fragment slot="head">
    <JsonLd data={schema} />
  </Fragment>

  <!-- Hero Section -->
  <section id="home-tools-container" class="mx-auto max-w-6xl px-4 sm:px-6 pt-12 pb-8">
    <div class="text-center mb-12">
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight mb-4">
        仕事で<span class="text-primary">安心</span>して使える
        <br class="hidden sm:block" />
        Webツール集
      </h1>
      <p class="text-lg text-muted-foreground max-w-2xl mx-auto leading-relaxed">
        すべてのツールがブラウザ内で完結。
        <br class="hidden sm:block" />
        サーバーへのデータ送信は<strong class="text-foreground">一切ありません</strong>。
      </p>
      <div class="mt-6 inline-flex items-center gap-2 rounded-full border border-safety/30 bg-safety/5 px-4 py-2 text-sm text-safety font-medium">
        <ShieldCheck className="h-4 w-4" />
        完全クライアントサイド処理 — 入力データはサーバーへ送信されません
      </div>
    </div>

    <!-- 1. 目的別ブロック -->
    <div class="mb-12 border-b border-border/50 pb-12">
      <h2 class="text-xl font-bold mb-6 flex items-center gap-2">
        <span class="text-2xl">🎯</span> 目的から探す
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {purposeCategories.map((purpose) => (
          <div class="rounded-xl border border-border bg-card p-5 shadow-xs">
            <h3 class="font-bold text-sm text-muted-foreground mb-4 flex items-center gap-1.5 border-b border-border/50 pb-2">
              <span class="text-base">{purpose.icon}</span> {purpose.title}
            </h3>
            <div class="flex flex-col gap-2">
              {purpose.tools.map((t) => (
                <a
                  href={t.href}
                  class="text-sm font-medium hover:text-primary transition-colors flex items-center justify-between p-2 rounded-lg hover:bg-muted/50 border border-transparent hover:border-border/30"
                >
                  <span>{t.name}</span>
                  <span class="text-xs text-muted-foreground opacity-50">→</span>
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- 2. 最近使ったツール -->
    <div id="recent-tools-section" class="mb-12 border-b border-border/50 pb-12 hidden">
      <h2 class="text-xl font-bold mb-6 flex items-center gap-2">
        <span class="text-2xl">🔁</span> 最近使ったツール
      </h2>
      <div id="recent-tools-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        <!-- JSで動的にクローンが挿入されます -->
      </div>
    </div>

    <!-- 3. よく使われるツール（人気順） -->
    <div class="mb-12 border-b border-border/50 pb-12">
      <h2 class="text-xl font-bold mb-6 flex items-center gap-2">
        <span class="text-2xl">⭐</span> よく使われるツール
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {popularTools.map((tool) => (
          <ToolCard
            id={tool.id}
            title={tool.title}
            description={tool.description}
            href={tool.href}
            icon={tool.icon}
            category={tool.category}
            categoryId={getCategoryId(tool.category)}
            categoryColor={tool.categoryColor}
          />
        ))}
      </div>
    </div>

    <!-- 4. すべてのツール（カテゴリ絞り込み） -->
    <div class="mb-12">
      <h2 class="text-xl font-bold mb-6 flex items-center gap-2">
        <span class="text-2xl">🗂️</span> すべてのツール
      </h2>

      <!-- Category filter chips -->
      <div
        id="category-filter"
        class="mb-8 flex flex-wrap gap-2"
        role="group"
        aria-label="カテゴリで絞り込み"
      >
        <button
          type="button"
          data-filter-chip=""
          aria-pressed="true"
          class="rounded-full border border-border bg-card px-3 py-1.5 text-sm font-medium text-muted-foreground transition-colors hover:bg-muted aria-pressed:border-primary aria-pressed:bg-primary aria-pressed:text-primary-foreground"
        >
          すべて
        </button>
        {toolCategories.map((category) => (
          <button
            type="button"
            data-filter-chip={category.id}
            aria-pressed="false"
            class="rounded-full border border-border bg-card px-3 py-1.5 text-sm font-medium text-muted-foreground transition-colors hover:bg-muted aria-pressed:border-primary aria-pressed:bg-primary aria-pressed:text-primary-foreground"
          >
            {category.name}
          </button>
        ))}
      </div>

      <!-- Bento Grid -->
      <div id="tool-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {toolCatalog.map((tool) => (
          <ToolCard
            id={tool.id}
            title={tool.title}
            description={tool.description}
            href={tool.href}
            icon={tool.icon}
            category={tool.category}
            categoryId={getCategoryId(tool.category)}
            categoryColor={tool.categoryColor}
            span={tool.span}
          />
        ))}

        <!-- Category summary card -->
        <div class="flex flex-col justify-center items-center rounded-xl border border-border bg-card p-5 text-center">
          <p class="text-3xl font-bold text-primary mb-1">{toolCatalog.length}</p>
          <p class="text-sm text-muted-foreground mb-3">ツールを公開中</p>
          <div class="flex flex-wrap justify-center gap-1.5">
            {toolCategories.map((category) => (
              <button
                type="button"
                data-category-badge={category.id}
                class={`text-xs rounded-full px-2 py-0.5 cursor-pointer transition-opacity hover:opacity-75 ${category.color}`}
              >
                {category.name}
              </button>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Features section -->
  <section class="mx-auto max-w-6xl px-4 sm:px-6 py-12">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
      <div class="text-center p-6 rounded-xl bg-card border border-border">
        <div class="text-3xl mb-3">🇯🇵</div>
        <h3 class="font-semibold mb-2">日本語業務に特化</h3>
        <p class="text-sm text-muted-foreground">全角半角変換、Shift-JISバイト数など、日本語業務で本当に必要な機能を搭載。</p>
      </div>
      <div class="text-center p-6 rounded-xl bg-card border border-border">
        <div class="text-3xl mb-3">🔒</div>
        <h3 class="font-semibold mb-2">完全クライアントサイド</h3>
        <p class="text-sm text-muted-foreground">すべてのデータ処理はブラウザ内で完結。機密データも安心して扱えます。</p>
      </div>
      <div class="text-center p-6 rounded-xl bg-card border border-border">
        <div class="text-3xl mb-3">⚡</div>
        <h3 class="font-semibold mb-2">高速・軽量</h3>
        <p class="text-sm text-muted-foreground">入力データを送信しないリアルタイム処理。ストレスフリーに使えます。</p>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  function setupCategoryFilter() {
    const filterContainer = document.getElementById('category-filter');
    const toolGrid = document.getElementById('tool-grid');
    // トップページ以外では何もしない
    if (!filterContainer || !toolGrid) return;
    // View Transitions 遷移ごとに DOM が再生成されるため、同一 DOM への二重バインドのみ防ぐ
    if (filterContainer.dataset.bound === 'true') return;
    filterContainer.dataset.bound = 'true';

    const chips = Array.from(
      filterContainer.querySelectorAll<HTMLButtonElement>('[data-filter-chip]'),
    );
    const validIds = new Set(
      chips
        .map((chip) => chip.getAttribute('data-filter-chip'))
        .filter((id) => id !== '' && id !== null),
    );

    /** カテゴリID（空文字 = すべて）でカード表示・チップ状態・URLを更新する */
    function applyFilter(categoryId: string, updateUrl: boolean) {
      for (const chip of chips) {
        const isActive = chip.getAttribute('data-filter-chip') === categoryId;
        chip.setAttribute('aria-pressed', String(isActive));
      }
      const cards = toolGrid?.querySelectorAll<HTMLElement>('[data-category]') ?? [];
      for (const card of cards) {
        card.classList.toggle(
          'hidden',
          categoryId !== '' && card.dataset.category !== categoryId,
        );
      }
      if (updateUrl) {
        const url = new URL(window.location.href);
        if (categoryId === '') {
          url.searchParams.delete('category');
        } else {
          url.searchParams.set('category', categoryId);
        }
        history.replaceState(null, '', url);
      }
    }

    filterContainer.addEventListener('click', (event) => {
      const chip = (event.target as Element).closest('[data-filter-chip]');
      if (!chip) return;
      applyFilter(chip.getAttribute('data-filter-chip') ?? '', true);
    });

    // カード内・サマリーカード内のカテゴリバッジクリックでも絞り込む
    const container = document.getElementById('home-tools-container');
    if (container) {
      container.addEventListener('click', (event) => {
        const badge = (event.target as Element).closest('[data-category-badge]');
        if (!badge) return;
        const categoryId = badge.getAttribute('data-category-badge');
        if (!categoryId || !validIds.has(categoryId)) return;
        event.preventDefault();
        applyFilter(categoryId, true);
      });
    }

    // `?category=<id>` での直アクセス・遷移時に初期フィルタを適用（不正値は「すべて」扱い）
    const initialId = new URL(window.location.href).searchParams.get('category') ?? '';
    if (initialId !== '') {
      applyFilter(validIds.has(initialId) ? initialId : '', false);
    }
  }

  function setupRecentTools() {
    const recentSection = document.getElementById('recent-tools-section');
    const recentGrid = document.getElementById('recent-tools-grid');
    const toolGrid = document.getElementById('tool-grid');
    if (!recentSection || !recentGrid || !toolGrid) return;

    try {
      const recentIds = JSON.parse(localStorage.getItem('recent_tools') || '[]');
      if (recentIds.length === 0) {
        recentSection.classList.add('hidden');
        return;
      }

      recentGrid.innerHTML = '';

      let hasItems = false;
      for (const id of recentIds) {
        const originCard = toolGrid.querySelector(`[data-tool-id="${id}"]`);
        if (originCard) {
          const clone = originCard.cloneNode(true) as HTMLElement;
          clone.classList.remove('hidden');
          // クローンしたカードはスパン指定を無視して1マス表示にする
          clone.className = clone.className.replace(/sm:col-span-\d/g, '').trim();
          recentGrid.appendChild(clone);
          hasItems = true;
        }
      }

      if (hasItems) {
        recentSection.classList.remove('hidden');
      } else {
        recentSection.classList.add('hidden');
      }
    } catch (e) {
      console.error('Failed to setup recent tools:', e);
    }
  }

  // 初回ロード時に実行
  setupCategoryFilter();
  setupRecentTools();

  // AstroのView Transitionsに対応するための再バインド処理
  document.addEventListener('astro:after-swap', () => {
    setupCategoryFilter();
    setupRecentTools();
  });
</script>
