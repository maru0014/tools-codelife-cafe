---
import BaseLayout from '../layouts/BaseLayout.astro';
import ToolCard from '../components/common/ToolCard.astro';
import { ShieldCheck } from 'lucide-react';
import { toolCatalog, toolCategories } from '../lib/tools/catalog';
const schema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "CODE:LIFE Tools",
  "url": "https://tools.codelife.cafe",
  "description": "仕事で安心して使える、高速・軽量なWebツール集",
  "inLanguage": "ja"
};
---

<BaseLayout
  title="仕事で安心して使えるWebツール集"
  description="すべてのツールがブラウザ内で完結。サーバーへのデータ送信は一切行わない、高速・軽量なWebツール集です。"
  path="/"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <!-- Hero Section -->
  <section class="mx-auto max-w-6xl px-4 sm:px-6 pt-12 pb-8">
    <div class="text-center mb-12">
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight mb-4">
        仕事で<span class="text-primary">安心</span>して使える
        <br class="hidden sm:block" />
        Webツール集
      </h1>
      <p class="text-lg text-muted-foreground max-w-2xl mx-auto leading-relaxed">
        すべてのツールがブラウザ内で完結。
        <br class="hidden sm:block" />
        サーバーへのデータ送信は<strong class="text-foreground">一切ありません</strong>。
      </p>
      <div class="mt-6 inline-flex items-center gap-2 rounded-full border border-safety/30 bg-safety/5 px-4 py-2 text-sm text-safety font-medium">
        <ShieldCheck className="h-4 w-4" />
        完全クライアントサイド処理 — 入力データはサーバーへ送信されません
      </div>
    </div>

    <!-- Bento Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {toolCatalog.map((tool) => (
        <ToolCard
          title={tool.title}
          description={tool.description}
          href={tool.href}
          icon={tool.icon}
          category={tool.category}
          categoryColor={tool.categoryColor}
          span={tool.span}
        />
      ))}

      <!-- Category summary card -->
      <div class="flex flex-col justify-center items-center rounded-xl border border-border bg-card p-5 text-center">
        <p class="text-3xl font-bold text-primary mb-1">{toolCatalog.length}</p>
        <p class="text-sm text-muted-foreground mb-3">ツールを公開中</p>
        <div class="flex flex-wrap justify-center gap-1.5">
          {toolCategories.map((category) => (
            <span class="text-xs rounded-full bg-primary/10 text-primary px-2 py-0.5">
              {category.name}
            </span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Features section -->
  <section class="mx-auto max-w-6xl px-4 sm:px-6 py-12">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
      <div class="text-center p-6 rounded-xl bg-card border border-border">
        <div class="text-3xl mb-3">🇯🇵</div>
        <h3 class="font-semibold mb-2">日本語業務に特化</h3>
        <p class="text-sm text-muted-foreground">全角半角変換、Shift-JISバイト数など、日本語業務で本当に必要な機能を搭載。</p>
      </div>
      <div class="text-center p-6 rounded-xl bg-card border border-border">
        <div class="text-3xl mb-3">🔒</div>
        <h3 class="font-semibold mb-2">完全クライアントサイド</h3>
        <p class="text-sm text-muted-foreground">すべてのデータ処理はブラウザ内で完結。機密データも安心して扱えます。</p>
      </div>
      <div class="text-center p-6 rounded-xl bg-card border border-border">
        <div class="text-3xl mb-3">⚡</div>
        <h3 class="font-semibold mb-2">高速・軽量</h3>
        <p class="text-sm text-muted-foreground">入力データを送信しないリアルタイム処理。ストレスフリーに使えます。</p>
      </div>
    </div>
  </section>
</BaseLayout>
