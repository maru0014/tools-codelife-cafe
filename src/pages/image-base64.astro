---
import { getEntry } from 'astro:content';
import ToolLayout from '../components/tool/ToolLayout.astro';
import { ImageBase64Page } from '../components/image-base64/ImageBase64Page';

const toolEntry = await getEntry('tools', 'image-base64');
if (!toolEntry) {
  throw new Error('Tool entry not found: image-base64');
}
---

<ToolLayout tool={toolEntry}>
  <ImageBase64Page client:load />
</ToolLayout>
