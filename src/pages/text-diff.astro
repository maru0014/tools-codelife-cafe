---
import { getEntry } from 'astro:content';
import ToolLayout from '../components/tool/ToolLayout.astro';
import TextDiffTool from '../components/tools/TextDiff.tsx';

const toolEntry = await getEntry('tools', 'text-diff');
if (!toolEntry) {
  throw new Error('Tool entry not found: text-diff');
}
---

<ToolLayout tool={toolEntry}>
  <TextDiffTool client:load />
</ToolLayout>
