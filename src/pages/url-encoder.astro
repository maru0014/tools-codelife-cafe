---
import { getEntry } from 'astro:content';
import ToolLayout from '../components/tool/ToolLayout.astro';
import UrlEncoderTool from '../components/tools/UrlEncoder.tsx';

const toolEntry = await getEntry('tools', 'url-encoder');
if (!toolEntry) {
  throw new Error('Tool entry not found: url-encoder');
}
---

<ToolLayout tool={toolEntry}>
  <UrlEncoderTool client:load />
</ToolLayout>
