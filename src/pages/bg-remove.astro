---
import { getEntry } from 'astro:content';
import ToolLayout from '../components/tool/ToolLayout.astro';
import BgRemoveTool from '../components/tools/BgRemove';

const toolEntry = await getEntry('tools', 'bg-remove');
if (!toolEntry) {
  throw new Error('Tool entry not found: bg-remove');
}
---

<ToolLayout tool={toolEntry}>
  <BgRemoveTool client:load />
</ToolLayout>
