---
import { getEntry } from 'astro:content';
import ToolLayout from '../components/tool/ToolLayout.astro';
import ImageTextPage from '../components/image-text/ImageTextPage';

const toolEntry = await getEntry('tools', 'image-text');
if (!toolEntry) {
  throw new Error('Tool entry not found: image-text');
}
---

<ToolLayout tool={toolEntry}>
  <ImageTextPage client:load />
</ToolLayout>
