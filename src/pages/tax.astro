---
import { getEntry } from 'astro:content';
import ToolLayout from '../components/tool/ToolLayout.astro';
import { TaxCalcPage } from '../components/tools/tax/TaxCalcPage';

const toolEntry = await getEntry('tools', 'tax');
if (!toolEntry) {
  throw new Error('Tool entry not found: tax');
}
---

<ToolLayout tool={toolEntry}>
  <TaxCalcPage client:load />
</ToolLayout>
