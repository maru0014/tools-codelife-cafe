---
import { getEntry } from 'astro:content';
import ToolLayout from '../components/tool/ToolLayout.astro';
import ImageMosaicPage from '../components/image-mosaic/ImageMosaicPage';

const toolEntry = await getEntry('tools', 'image-mosaic');
if (!toolEntry) {
  throw new Error('Tool entry not found: image-mosaic');
}
---

<ToolLayout tool={toolEntry}>
  <ImageMosaicPage client:load />
</ToolLayout>
