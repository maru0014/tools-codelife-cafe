---
import { getEntry } from 'astro:content';
import ToolLayout from '../components/tool/ToolLayout.astro';
import { ColorConvertPage } from '../components/tools/color/ColorConvertPage';

const toolEntry = await getEntry('tools', 'color');
if (!toolEntry) {
  throw new Error('Tool entry not found: color');
}
---

<ToolLayout tool={toolEntry}>
  <ColorConvertPage client:load />
</ToolLayout>
