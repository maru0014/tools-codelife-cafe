---
import { getEntry } from 'astro:content';
import ToolLayout from '../components/tool/ToolLayout.astro';
import { PdfSplitPage } from '../components/pdf-split/PdfSplitPage';

const toolEntry = await getEntry('tools', 'pdf-split');
if (!toolEntry) {
  throw new Error('Tool entry not found: pdf-split');
}
---

<ToolLayout tool={toolEntry}>
  <PdfSplitPage client:load />
</ToolLayout>
