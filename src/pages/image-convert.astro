---
import { getEntry } from 'astro:content';
import ToolLayout from '../components/tool/ToolLayout.astro';
import { ImageConvertPage } from '../components/image-convert/ImageConvertPage';

const toolEntry = await getEntry('tools', 'image-convert');
if (!toolEntry) {
  throw new Error('Tool entry not found: image-convert');
}
---

<ToolLayout tool={toolEntry}>
  <ImageConvertPage client:load />
</ToolLayout>
