---
import { getEntry } from 'astro:content';
import ToolLayout from '../components/tool/ToolLayout.astro';
import { ImageCompressPage } from '../components/image-compress/ImageCompressPage';

const toolEntry = await getEntry('tools', 'image-compress');
if (!toolEntry) {
  throw new Error('Tool entry not found: image-compress');
}
---

<ToolLayout tool={toolEntry}>
  <ImageCompressPage client:load />
</ToolLayout>
