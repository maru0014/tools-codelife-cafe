---
import { getEntry } from 'astro:content';
import ToolLayout from '../components/tool/ToolLayout.astro';
import { OgpGeneratorPage } from '../components/ogp/OgpGeneratorPage';

const toolEntry = await getEntry('tools', 'ogp');
if (!toolEntry) {
  throw new Error('Tool entry not found: ogp');
}
---

<ToolLayout tool={toolEntry}>
  <OgpGeneratorPage client:load />
</ToolLayout>
