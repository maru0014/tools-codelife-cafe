---
import { getEntry } from 'astro:content';
import ToolLayout from '../components/tool/ToolLayout.astro';
import { MarkdownPreviewPage } from '../components/tools/markdown/MarkdownPreviewPage';

const toolEntry = await getEntry('tools', 'markdown');
if (!toolEntry) {
  throw new Error('Tool entry not found: markdown');
}
---

<ToolLayout tool={toolEntry}>
  <MarkdownPreviewPage client:load />
</ToolLayout>
