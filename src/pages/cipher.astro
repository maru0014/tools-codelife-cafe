---
import { getEntry } from 'astro:content';
import ToolLayout from '../components/tool/ToolLayout.astro';
import { CipherPage } from '../components/tools/cipher/CipherPage';

const toolEntry = await getEntry('tools', 'cipher');
if (!toolEntry) {
  throw new Error('Tool entry not found: cipher');
}
---

<ToolLayout tool={toolEntry}>
  <CipherPage client:load />
</ToolLayout>
