---
import { getEntry } from 'astro:content';
import ToolLayout from '../components/tool/ToolLayout.astro';
import { ImageMetadataPage } from '../components/image-metadata/ImageMetadataPage';

const toolEntry = await getEntry('tools', 'image-metadata');
if (!toolEntry) {
  throw new Error('Tool entry not found: image-metadata');
}
---

<ToolLayout tool={toolEntry}>
  <ImageMetadataPage client:load />
</ToolLayout>
