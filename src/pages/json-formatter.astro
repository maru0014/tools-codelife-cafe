---
import { getEntry } from 'astro:content';
import ToolLayout from '../components/tool/ToolLayout.astro';
import JsonFormatterTool from '../components/tools/JsonFormatter.tsx';

const toolEntry = await getEntry('tools', 'json-formatter');
if (!toolEntry) {
  throw new Error('Tool entry not found: json-formatter');
}
---

<ToolLayout tool={toolEntry}>
  <JsonFormatterTool client:load />
</ToolLayout>
