---
import { getEntry } from 'astro:content';
import ToolLayout from '../components/tool/ToolLayout.astro';
import DummyDataGenerator from '../components/tools/DummyDataGenerator.tsx';

const toolEntry = await getEntry('tools', 'dummy-data');
if (!toolEntry) {
  throw new Error('Tool entry not found: dummy-data');
}
---

<ToolLayout tool={toolEntry}>
  <DummyDataGenerator client:load />
</ToolLayout>
