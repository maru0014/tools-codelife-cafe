---
import { getEntry } from 'astro:content';
import ToolLayout from '../components/tool/ToolLayout.astro';
import { AiSpreadsheetPrompt } from '../components/tools/AiSpreadsheetPrompt';

const toolEntry = await getEntry('tools', 'ai-spreadsheet-prompt');
if (!toolEntry) {
  throw new Error('Tool entry not found: ai-spreadsheet-prompt');
}
---

<ToolLayout tool={toolEntry}>
  <AiSpreadsheetPrompt client:load />
</ToolLayout>
