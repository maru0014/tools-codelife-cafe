---
import { getEntry } from 'astro:content';
import ToolLayout from '../components/tool/ToolLayout.astro';
import UnicodeConverterTool from '../components/tools/UnicodeConverter.tsx';

const toolEntry = await getEntry('tools', 'unicode-converter');
if (!toolEntry) {
  throw new Error('Tool entry not found: unicode-converter');
}
---

<ToolLayout tool={toolEntry}>
  <UnicodeConverterTool client:load />
</ToolLayout>
