---
import { getEntry } from 'astro:content';
import ToolLayout from '../components/tool/ToolLayout.astro';
import MaskingTool from '../components/tools/Masking.tsx';

const toolEntry = await getEntry('tools', 'masking');
if (!toolEntry) {
  throw new Error('Tool entry not found: masking');
}
---

<ToolLayout tool={toolEntry}>
  <MaskingTool client:load />
</ToolLayout>
