---
import { getEntry } from 'astro:content';
import ToolLayout from '../components/tool/ToolLayout.astro';
import { ImageCropPage } from '../components/image-crop/ImageCropPage';

const toolEntry = await getEntry('tools', 'image-crop');
if (!toolEntry) {
  throw new Error('Tool entry not found: image-crop');
}
---

<ToolLayout tool={toolEntry}>
  <ImageCropPage client:load />
</ToolLayout>
