---
import { getEntry } from 'astro:content';
import ToolLayout from '../components/tool/ToolLayout.astro';
import WarekiConverterTool from '../components/tools/WarekiConverter.tsx';

const toolEntry = await getEntry('tools', 'wareki-converter');
if (!toolEntry) {
  throw new Error('Tool entry not found: wareki-converter');
}
---

<ToolLayout tool={toolEntry}>
  <WarekiConverterTool client:load />
</ToolLayout>
