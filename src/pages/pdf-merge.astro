---
import { getEntry } from 'astro:content';
import ToolLayout from '../components/tool/ToolLayout.astro';
import { PdfMergePage } from '../components/pdf-merge/PdfMergePage';

const toolEntry = await getEntry('tools', 'pdf-merge');
if (!toolEntry) {
  throw new Error('Tool entry not found: pdf-merge');
}
---

<ToolLayout tool={toolEntry}>
  <PdfMergePage client:load />
</ToolLayout>
