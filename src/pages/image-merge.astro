---
import { getEntry } from 'astro:content';
import ToolLayout from '../components/tool/ToolLayout.astro';
import ImageMergePage from '../components/image-merge/ImageMergePage';

const toolEntry = await getEntry('tools', 'image-merge');
if (!toolEntry) {
  throw new Error('Tool entry not found: image-merge');
}
---

<ToolLayout tool={toolEntry}>
  <ImageMergePage client:load />
</ToolLayout>
