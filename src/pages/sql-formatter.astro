---
import { getEntry } from 'astro:content';
import ToolLayout from '../components/tool/ToolLayout.astro';
import SqlFormatterTool from '../components/tools/SqlFormatter.tsx';

const toolEntry = await getEntry('tools', 'sql-formatter');
if (!toolEntry) {
  throw new Error('Tool entry not found: sql-formatter');
}
---

<ToolLayout tool={toolEntry}>
  <SqlFormatterTool client:load />
</ToolLayout>
