---
import { getEntry } from 'astro:content';
import ToolLayout from '../components/tool/ToolLayout.astro';
import QrReader from '../components/tools/QrReader';

const toolEntry = await getEntry('tools', 'qr-reader');
if (!toolEntry) {
  throw new Error('Tool entry not found: qr-reader');
}
---

<ToolLayout tool={toolEntry}>
  <QrReader client:load />
</ToolLayout>
