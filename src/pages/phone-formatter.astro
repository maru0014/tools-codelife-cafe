---
import { getEntry } from 'astro:content';
import ToolLayout from '../components/tool/ToolLayout.astro';
import PhoneFormatterPage from '../components/phone-formatter/PhoneFormatterPage';

const toolEntry = await getEntry('tools', 'phone-formatter');
if (!toolEntry) {
  throw new Error('Tool entry not found: phone-formatter');
}
---

<ToolLayout tool={toolEntry}>
  <PhoneFormatterPage client:load />
</ToolLayout>
