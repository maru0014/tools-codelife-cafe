---
import { getEntry } from 'astro:content';
import ToolLayout from '../components/tool/ToolLayout.astro';
import CsvFixerTool from '../components/tools/CsvFixer';

const toolEntry = await getEntry('tools', 'csv-fixer');
if (!toolEntry) {
  throw new Error('Tool entry not found: csv-fixer');
}
---

<ToolLayout tool={toolEntry}>
  <CsvFixerTool client:load />
</ToolLayout>
