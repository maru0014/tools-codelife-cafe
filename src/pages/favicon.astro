---
import { getEntry } from 'astro:content';
import ToolLayout from '../components/tool/ToolLayout.astro';
import { FaviconGeneratorPage } from '../components/favicon/FaviconGeneratorPage';

const toolEntry = await getEntry('tools', 'favicon');
if (!toolEntry) {
  throw new Error('Tool entry not found: favicon');
}
---

<ToolLayout tool={toolEntry}>
  <FaviconGeneratorPage client:load />
</ToolLayout>
