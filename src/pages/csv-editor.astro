---
import { getEntry } from 'astro:content';
import ToolLayout from '../components/tool/ToolLayout.astro';
import CsvEditorTool from '../components/tools/CsvEditor.tsx';

const toolEntry = await getEntry('tools', 'csv-editor');
if (!toolEntry) {
  throw new Error('Tool entry not found: csv-editor');
}
---

<ToolLayout tool={toolEntry}>
  <CsvEditorTool client:load />
</ToolLayout>
