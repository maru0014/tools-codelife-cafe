---
import { getEntry } from 'astro:content';
import ToolLayout from '../components/tool/ToolLayout.astro';
import ZenkakuHankakuTool from '../components/tools/ZenkakuHankaku.tsx';

const toolEntry = await getEntry('tools', 'zenkaku-hankaku');
if (!toolEntry) {
  throw new Error('Tool entry not found: zenkaku-hankaku');
}
---

<ToolLayout tool={toolEntry}>
  <ZenkakuHankakuTool client:load />
</ToolLayout>
