---
import { getEntry } from 'astro:content';
import ToolLayout from '../components/tool/ToolLayout.astro';
import ImageEditPage from '../components/image-edit/ImageEditPage';

const toolEntry = await getEntry('tools', 'image-edit');
if (!toolEntry) {
  throw new Error('Tool entry not found: image-edit');
}
---

<ToolLayout tool={toolEntry}>
  <ImageEditPage client:load />
</ToolLayout>
