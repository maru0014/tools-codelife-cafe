---
import { getEntry } from 'astro:content';
import ToolLayout from '../components/tool/ToolLayout.astro';
import { HashPage } from '../components/tools/hash-generator/HashPage';

const toolEntry = await getEntry('tools', 'hash');
if (!toolEntry) {
  throw new Error('Tool entry not found: hash');
}
---

<ToolLayout tool={toolEntry}>
  <HashPage client:load />
</ToolLayout>
