---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolHero from './ToolHero.astro';
import UseCases from './UseCases.astro';
import HowTo from './HowTo.astro';
import Faq from './Faq.astro';
import RelatedTools from './RelatedTools.astro';
import WorkflowNav from './WorkflowNav.astro';
import { getWorkflowToolIds } from '../../lib/tools/workflow-sets';
import { getCategoryId, toolCatalog, type ToolCategory } from '../../lib/tools/catalog';
import { generateJsonLd } from '../../lib/jsonld';

interface Props {
	tool: CollectionEntry<'tools'>;
	path?: string;
}

const { tool: entry, path: customPath } = Astro.props;
const { title, description, canonical, category, summary, useCases, howto, faq, related, updated } = entry.data;

const toolId = entry.id;
const workflowExcludeIds = getWorkflowToolIds(toolId);
const catalogTool = toolCatalog.find((t) => t.id === toolId);
const path = customPath || catalogTool?.href || `/tools/${toolId}`;
const SITE_URL = 'https://tools.codelife.cafe';
const canonicalUrl = canonical || `${SITE_URL}${path}`;

// パンくずリスト用
const categoryHref = category ? `/?category=${getCategoryId(category as ToolCategory)}` : undefined;

const ogImage = catalogTool ? `/og/${catalogTool.id}.png` : undefined;

const jsonLdData = generateJsonLd(
	{
		title,
		path,
		summary,
		category,
		howto,
		faq,
	},
	categoryHref,
);
---

<BaseLayout title={title} description={description} path={path} ogImage={ogImage}>
	<Fragment slot="head">
		{canonical && <link rel="canonical" href={canonicalUrl} />}
		<script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLdData).replace(/</g, '\\u003c')} />
		<slot name="head" />
	</Fragment>

	<div id="tool-layout-container" class="transition-all duration-300 mx-auto max-w-[800px] xl:max-w-5xl px-4 sm:px-6 py-8">
		<!-- Breadcrumbs -->
		<nav aria-label="パンくずリスト" class="mb-6">
			<ol class="flex flex-wrap items-center gap-1.5 text-sm text-muted-foreground">
				<li>
					<a href="/" class="hover:text-foreground transition-colors">ホーム</a>
				</li>
				{category && categoryHref && (
					<li class="flex items-center gap-1.5">
						<span aria-hidden="true">›</span>
						<a href={categoryHref} class="hover:text-foreground transition-colors">{category}</a>
					</li>
				)}
				<li class="flex items-center gap-1.5">
					<span aria-hidden="true">›</span>
					<span aria-current="page" class="text-foreground font-medium">{title}</span>
				</li>
			</ol>
		</nav>

		<!-- 1. Hero セクション -->
		<ToolHero title={title} summary={summary} updated={updated} />

		<!-- 4. ツール本体 (React Island 等) -->
		<section class="my-8 rounded-2xl border border-border/80 bg-card p-4 sm:p-6 shadow-xs" aria-label="ツール操作エリア">
			<slot />
		</section>

		<!-- 2. UseCases セクション -->
		<UseCases useCases={useCases} />

		<!-- 3. HowTo セクション -->
		<HowTo howto={howto} />

		<!-- 5. FAQ セクション -->
		<Faq faq={faq} />

		<!-- 6. Workflow Nav セクション -->
		<WorkflowNav toolId={toolId} />

		<!-- 7. Related Tools セクション -->
		<RelatedTools toolId={toolId} relatedSlugs={related} excludeIds={workflowExcludeIds} />
	</div>

	<script define:vars={{ toolId }}>
		try {
			const MAX_HISTORY = 4;
			const historyKey = 'recent_tools';
			const recent = JSON.parse(localStorage.getItem(historyKey) || '[]');
			const updated = [toolId, ...recent.filter((id) => id !== toolId)].slice(0, MAX_HISTORY);
			localStorage.setItem(historyKey, JSON.stringify(updated));
		} catch (e) {
			console.error('Failed to save recent tool in history:', e);
		}
	</script>
</BaseLayout>

