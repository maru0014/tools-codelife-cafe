---
import ThemeToggle from '../common/ThemeToggle.tsx';
import SearchModal from '../common/SearchModal.tsx';
import OfflineBadge from './OfflineBadge.tsx';
import { FileText } from 'lucide-react';
---

<header class="sticky top-0 z-50 border-b border-border bg-background/80 backdrop-blur-lg">
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-4 sm:px-6">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 font-bold text-lg tracking-tight hover:opacity-80 transition-opacity">
      <span class="hidden sm:inline">CODE:LIFE Tools</span>
      <span class="sm:hidden">C:L Tools</span>
    </a>

    <!-- Center: Search hint -->
    <div class="flex items-center">
      <button
        type="button"
        class="flex items-center justify-center gap-2 rounded-lg md:border md:border-border md:bg-muted/50 p-2 md:px-4 md:py-1.5 text-sm text-muted-foreground hover:bg-muted transition-colors"
        id="search-trigger"
        title="検索 (Ctrl+K)"
        aria-label="ツールを検索"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" class="md:w-4 md:h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path></svg>
        <span class="hidden md:inline">ツールを検索...</span>
        <kbd id="search-kbd" class="hidden md:inline ml-2 rounded border border-border bg-background px-1.5 py-0.5 text-xs font-mono">Ctrl+K</kbd>
      </button>
    </div>

    <!-- Right: Theme toggle -->
    <div class="flex items-center gap-3">
      <OfflineBadge client:load />
      <a
        href="/privacy"
        class="inline-flex items-center gap-1.5 rounded-lg p-2 text-muted-foreground hover:bg-muted hover:text-foreground transition-colors md:px-3"
        title="プライバシーポリシーを開く"
        aria-label="プライバシーポリシー"
      >
        <FileText className="h-5 w-5 md:h-4 md:w-4" aria-hidden="true" />
        <span class="hidden lg:inline text-sm font-medium">プライバシー</span>
      </a>
      <a
        href="https://github.com/code-life-cafe/tools-codelife-cafe"
        target="_blank"
        rel="noopener noreferrer"
        class="rounded-lg p-2 text-muted-foreground hover:bg-muted hover:text-foreground transition-colors"
        title="GitHubリポジトリを開く"
        aria-label="GitHub"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"></path></svg>
      </a>
      <ThemeToggle client:load />
    </div>
  </div>
  <SearchModal client:load />
</header>

<script>
  function setupSearchTrigger() {
    const searchTrigger = document.getElementById('search-trigger');
    if (searchTrigger) {
      // 既存リスナーの重複を防ぐためclone & replace
      const newTrigger = searchTrigger.cloneNode(true) as Element;
      searchTrigger.parentNode?.replaceChild(newTrigger, searchTrigger);
      newTrigger.addEventListener('click', () => {
        window.dispatchEvent(new CustomEvent('open-search'));
      });
    }

    // OS判定でショートカットキー表記を設定
    const kbdElement = document.getElementById('search-kbd');
    if (kbdElement) {
      const isMac = navigator.userAgent.includes('Mac');
      kbdElement.textContent = isMac ? '⌘K' : 'Ctrl+K';
    }
  }

  // 初回ロード時に実行
  setupSearchTrigger();
</script>

