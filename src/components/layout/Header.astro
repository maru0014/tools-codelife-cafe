---
import ThemeToggle from '../common/ThemeToggle.tsx';
import SearchModal from '../common/SearchModal.tsx';
---

<header class="sticky top-0 z-50 border-b border-border bg-background/80 backdrop-blur-lg">
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-4 sm:px-6">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 font-bold text-lg tracking-tight hover:opacity-80 transition-opacity">
      <span class="text-primary">🔒</span>
      <span class="hidden sm:inline">CODE:LIFE Tools</span>
      <span class="sm:hidden">C:L Tools</span>
    </a>

    <!-- Center: Search hint -->
    <div class="flex items-center">
      <button
        type="button"
        class="flex items-center justify-center gap-2 rounded-lg md:border md:border-border md:bg-muted/50 p-2 md:px-4 md:py-1.5 text-sm text-muted-foreground hover:bg-muted transition-colors"
        id="search-trigger"
        title="検索 (Ctrl+K)"
        aria-label="ツールを検索"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" class="md:w-4 md:h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path></svg>
        <span class="hidden md:inline">ツールを検索...</span>
        <kbd id="search-kbd" class="hidden md:inline ml-2 rounded border border-border bg-background px-1.5 py-0.5 text-xs font-mono">Ctrl+K</kbd>
      </button>
    </div>

    <!-- Right: Theme toggle -->
    <div class="flex items-center gap-3">
      <span class="hidden lg:flex items-center gap-1.5 text-xs text-safety font-medium">
        <span class="inline-block h-2 w-2 rounded-full bg-safety pulse-dot"></span>
        オフライン対応
      </span>
      <ThemeToggle client:load />
    </div>
  </div>
  <SearchModal client:load />
</header>

<script>
  function setupSearchTrigger() {
    const searchTrigger = document.getElementById('search-trigger');
    if (searchTrigger) {
      // 既存リスナーの重複を防ぐためclone & replace
      const newTrigger = searchTrigger.cloneNode(true) as Element;
      searchTrigger.parentNode?.replaceChild(newTrigger, searchTrigger);
      newTrigger.addEventListener('click', () => {
        window.dispatchEvent(new CustomEvent('open-search'));
      });
    }

    // OS判定でショートカットキー表記を設定
    const kbdElement = document.getElementById('search-kbd');
    if (kbdElement) {
      const isMac = navigator.userAgent.includes('Mac');
      kbdElement.textContent = isMac ? '⌘K' : 'Ctrl+K';
    }
  }

  // 初回ロード時とView Transitionsによるページ遷移時の両方で実行
  setupSearchTrigger();
  document.addEventListener('astro:page-load', setupSearchTrigger);
</script>
