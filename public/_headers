/*
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' 'wasm-unsafe-eval' blob: https://cdn.jsdelivr.net https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: blob: https:; connect-src 'self' blob: https://models.tools.codelife.cafe https://huggingface.co https://*.huggingface.co https://*.hf.co https://*.xethub.hf.co https://cdn.jsdelivr.net https://cloudflareinsights.com; font-src 'self' https://fonts.gstatic.com
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Embedder-Policy: credentialless

# /transcribe（ローカル文字起こし）は「音声・テキストを一切外部へ出さない」ことが不変条件のため、
# サイト共通ポリシーより厳しい CSP を重ねる（connect-src を self に限定し、jsDelivr / Hugging Face /
# 計測エンドポイントへの接続を塞ぐ）。ページ側でも同等の meta を出力しており、
# astro preview / E2E ではそちらが実効ポリシーになる（src/lib/transcribe/csp.ts が正本）。
/transcribe
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' 'wasm-unsafe-eval' blob:; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; media-src 'self' blob:; font-src 'self'; connect-src 'self'; worker-src 'self' blob:; child-src 'self' blob:; manifest-src 'self'; base-uri 'self'; form-action 'self'

/transcribe/*
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' 'wasm-unsafe-eval' blob:; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; media-src 'self' blob:; font-src 'self'; connect-src 'self'; worker-src 'self' blob:; child-src 'self' blob:; manifest-src 'self'; base-uri 'self'; form-action 'self'

# モデルと ONNX Runtime WASM は、**URL 自体にバージョン識別子を含む**ため長期キャッシュ可能。
#   /models/transcribe/<name>/<revision>/...
#   /vendor/onnx-wasm/<onnxruntime-web のバージョン>/...
# 内容が変わればパスも変わるので、immutable で配っても古い成果物が残らない。
# 固定 URL の内容を差し替える運用にしてはいけない（最大1年キャッシュに残る）。
/models/transcribe/*
  Cache-Control: public, max-age=31536000, immutable

/vendor/onnx-wasm/*
  Cache-Control: public, max-age=31536000, immutable

# AIエージェント向けディスカバリー（RFC 8288 Link ヘッダー）。
# 機械可読リソース（llms.txt / Agent Skills index）の場所をトップページで通知する。
/
  Link: </llms.txt>; rel="describedby"; type="text/plain", </.well-known/agent-skills/index.json>; rel="describedby"; type="application/json"
