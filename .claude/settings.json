{
  "permissions": {
    "defaultMode": "default",
    "allow": [
      "Bash(npm test)",
      "Bash(npm run*)",
      "Bash(npx playwright*)",
      "Bash(npx astro*)",
      "Bash(npx biome*)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git branch*)",
      "Bash(git checkout*)",
      "Bash(git switch*)"
    ],
    "deny": [
      "Write(*.env)",
      "Write(.env.*)",
      "Edit(*.env)",
      "Edit(.env.*)",
      "Edit(.git/*)"
    ]
  }
}
